# Copy to .env. All vars are read from ./.env.

# --- coilmem service ---
COILMEM_KEY=dev-secret
COILMEM_DB=coilmem.db

# --- embeddings --- local needs no key
EMBED_PROVIDER=local              # local | openai | gemini

# --- LLM provider keys (team live runs; openai/gemini embeddings) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
